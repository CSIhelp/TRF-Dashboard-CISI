    <div class="db-card">
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>Employee</th>
              <th>Type</th>
              <th>From</th>
              <th>To</th>
              <th>Department</th>
              <th>Status</th>
              <th>Stage</th>
              <th>Submitted</th>
              <th>Actions</th>
