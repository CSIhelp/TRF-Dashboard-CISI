// ── LOAD APPROVALS ──
async function loadApprovals() {
  document.getElementById('approvalTableBody').innerHTML =
    `<tr><td colspan="9" class="state-cell"><span class="spinner"></span> Loading...</td></tr>`;
  try {
    const url = currentRole === 'supervisor'
      ? `${BASE_URL}/get-trf-approvals?role=supervisor&email=${encodeURIComponent(window.currentUserEmail)}`
      : `${BASE_URL}/get-trf-approvals?role=hr`;

    const res  = await fetch(url);
    const raw  = await res.json();
    allData    = Array.isArray(raw) ? raw.map(i => i.json ?? i) : [];

    updateStats();
    applyFilter();
  } catch(err) {
    document.getElementById('approvalTableBody').innerHTML =
      `<tr><td colspan="9" class="state-cell" style="color:#dc2626">Failed to load. Check console.</td></tr>`;
  }
}

function updateStats() {
  const pending  = allData.filter(r => r.approval_status === 'Pending').length;
  const approved = allData.filter(r => r.approval_status === 'Approved').length;
  const rejected = allData.filter(r => r.approval_status === 'Rejected').length;

  document.getElementById('statPending').textContent  = pending;
  document.getElementById('statApproved').textContent = approved;
  document.getElementById('statRejected').textContent = rejected;
  document.getElementById('statTotal').textContent    = allData.length;

  const badge = document.getElementById('sidebarBadge');
  if (pending > 0) { badge.textContent = pending; badge.style.display = 'inline-block'; }
  else              { badge.style.display = 'none'; }
}

function setFilter(filter, btn) {
  currentFilter = filter;
  document.querySelectorAll('.filter-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  applyFilter();
}

function applyFilter() {
  const search = document.getElementById('searchInput')?.value?.toLowerCase() || '';
  filteredData = allData.filter(r => {
    const matchFilter = currentFilter === 'all' || r.approval_status === currentFilter;
    const matchSearch = !search || [r.employee_name, r.request_type, r.department]
      .some(v => String(v||'').toLowerCase().includes(search));
    return matchFilter && matchSearch;
  });
  renderTable();
}

function filterTable(val) { applyFilter(); }

function fmtDate(d) {
  if (!d) return '—';
  return new Date(d).toLocaleString('en-PH', { month:'short', day:'numeric', year:'numeric', hour:'numeric', minute:'2-digit', hour12:true, timeZone:'Asia/Manila' });
}

function fmtShort(d) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('en-PH', { month:'short', day:'numeric', year:'numeric', timeZone:'Asia/Manila' });
}

function renderTable() {
  const tbody = document.getElementById('approvalTableBody');
  if (!filteredData.length) {
    tbody.innerHTML = `<tr><td colspan="9" class="state-cell">No records found.</td></tr>`;
    return;
  }

  tbody.innerHTML = filteredData.map(r => {
    const statusCls = r.approval_status === 'Approved' ? 'badge-approved' :
                      r.approval_status === 'Rejected' ? 'badge-rejected' : 'badge-pending';
    const stageLbl  = currentRole === 'hr' ? 'HR' : 'Supervisor';
    const canAct    = r.approval_status === 'Pending';

    return `<tr>
      <td style="font-weight:600">${r.employee_name || '—'}</td>
      <td>${r.request_type || '—'}</td>
      <td>${fmtShort(r.start_time)}</td>
      <td>${fmtShort(r.end_time)}</td>
      <td>${r.department || '—'}</td>
      <td><span class="badge ${statusCls}">${r.approval_status || 'Pending'}</span></td>
      <td><span class="badge badge-${currentRole === 'hr' ? 'hr' : 'supervisor'}">${stageLbl}</span></td>
      <td style="color:var(--text-muted)">${fmtShort(r.submitted_at)}</td>
      <td>
        <div style="display:flex;gap:5px">
          <button class="btn btn-view" onclick="openActionModal(${JSON.stringify(r).replace(/"/g,'&quot;')})">👁 Review</button>
          ${canAct ? `
            <button class="btn btn-approve" onclick="quickAction(${JSON.stringify(r).replace(/"/g,'&quot;')},'approve')">✅</button>
            <button class="btn btn-reject"  onclick="quickAction(${JSON.stringify(r).replace(/"/g,'&quot;')},'reject')">❌</button>
          ` : ''}
        </div>
      </td>
    </tr>`;
  }).join('');
}

// ── MODAL ──
function openActionModal(trf) {
  pendingTRF = trf;
  document.getElementById('actionModalTitle').textContent = `Review — ${trf.employee_name}`;

  // Leave strip
  const totalDays = computeDays(trf.start_time, trf.end_time);
  const silUsed   = parseFloat(trf.sil_amount || 0);
  const unpaid    = trf.use_credits === 'Yes' ? Math.max(0, totalDays - silUsed) : totalDays;

  document.getElementById('mdTotalDays').textContent = totalDays.toFixed(1);
  document.getElementById('mdSIL').textContent       = silUsed.toFixed(1);
  document.getElementById('mdUnpaid').textContent    = unpaid.toFixed(1);
  document.getElementById('mdUnpaid').style.color    = unpaid > 0 ? '#dc2626' : '#15803d';

  // Details
  document.getElementById('mdEmployee').textContent = trf.employee_name || '—';
  document.getElementById('mdDept').textContent     = trf.department || '—';
  document.getElementById('mdJobTitle').textContent = trf.job_title || '—';
  document.getElementById('mdType').textContent     = trf.request_type || '—';
  document.getElementById('mdFrom').textContent     = fmtDate(trf.start_time);
  document.getElementById('mdTo').textContent       = fmtDate(trf.end_time);
  document.getElementById('mdReason').textContent   = trf.reason || 'N/A';
  document.getElementById('mdCredits').textContent  = trf.use_credits || '—';

  // Doc links
  if (trf.supporting_doc_filename && trf.supporting_doc_filename.startsWith('http')) {
    document.getElementById('mdDoc').href = trf.supporting_doc_filename;
    document.getElementById('mdDocRow').style.display = 'flex';
  } else {
    document.getElementById('mdDocRow').style.display = 'none';
  }

  if (trf.trf_link && trf.trf_link.startsWith('http')) {
    document.getElementById('mdTRF').href = trf.trf_link;
    document.getElementById('mdTRFRow').style.display = 'flex';
  } else {
    document.getElementById('mdTRFRow').style.display = 'none';
  }

  // Pre-fill name
  document.getElementById('decisionName').value    = supervisorInfo?.name || '';
  document.getElementById('decisionRemarks').value = '';
  document.getElementById('decisionPaid').value    = 'N/A';
  document.getElementById('decisionExcused').value = 'N/A';

  // Show/hide action buttons based on status
  const canAct = trf.approval_status === 'Pending';
  document.getElementById('modalApproveBtn').style.display = canAct ? 'inline-flex' : 'none';
  document.getElementById('modalRejectBtn').style.display  = canAct ? 'inline-flex' : 'none';

  document.getElementById('actionModal').classList.add('active');
}

function closeActionModal() {
  document.getElementById('actionModal').classList.remove('active');
  pendingTRF = null;
}

function quickAction(trf, decision) {
  pendingTRF = trf;
  document.getElementById('decisionName').value    = supervisorInfo?.name || '';
  document.getElementById('decisionRemarks').value = '';
  // Open modal pre-filled
  openActionModal(trf);
}

async function submitDecision(decision) {
  if (!pendingTRF) return;
  const name    = document.getElementById('decisionName').value.trim();
  const remarks = document.getElementById('decisionRemarks').value.trim();
  const paid    = document.getElementById('decisionPaid').value;
  const excused = document.getElementById('decisionExcused').value;

  if (!name)    { showToast('Please enter your name.', 'error'); return; }
  if (!remarks) { showToast('Please add remarks.', 'error'); return; }

  const approveBtn = document.getElementById('modalApproveBtn');
  const rejectBtn  = document.getElementById('modalRejectBtn');
  approveBtn.disabled = true; rejectBtn.disabled = true;
  const btn = decision === 'approve' ? approveBtn : rejectBtn;
  btn.innerHTML = '<span class="spinner" style="border-top-color:currentColor"></span> Submitting...';

  try {
    // Use the n8n wait webhook resume URL pattern
    // Build the resume URL from the TRF's resume_url stored in DB
    // If resume_url exists in trf data, use it; otherwise call our action endpoint
    const actionUrl = currentRole === 'supervisor'
      ? `${BASE_URL}/trf-dashboard-action`
      : `${BASE_URL}/trf-dashboard-action-hr`;

    const res = await fetch(actionUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        uid:        pendingTRF.uid,
        action:     decision,
        by:         name,
        remarks:    remarks,
        paid:       paid,
        excused:    excused,
        role:       currentRole,
        sil_amount: pendingTRF.sil_amount || '0'
      })
    });

    const data = await res.json();
    if (res.ok && (data.success !== false)) {
      showToast(`TRF ${decision === 'approve' ? 'Approved' : 'Rejected'} successfully!`, 'success');
      closeActionModal();
      setTimeout(() => loadApprovals(), 1000);
    } else {
      showToast(data.message || 'Action failed. Please try again.', 'error');
    }
  } catch(err) {
    showToast('Network error: ' + err.message, 'error');
  } finally {
    approveBtn.disabled = false; rejectBtn.disabled = false;
    approveBtn.innerHTML = '✅ Approve';
    rejectBtn.innerHTML  = '❌ Reject';
  }
}

function computeDays(start, end) {
  if (!start || !end) return 0;
  return Math.round(((new Date(end) - new Date(start)) / (1000*60*60*24)) * 2) / 2;
}

function showToast(msg, type = '') {
  const t = document.getElementById('toast');
  t.textContent = (type === 'error' ? '❌ ' : '✅ ') + msg;
  t.className = 'toast' + (type ? ' ' + type : '');
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 4500);
}

init();
