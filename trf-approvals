      <div class="stat-card approved"><div class="stat-num" id="statApproved">—</div><div class="stat-label">Approved</div></div>
      <div class="stat-card rejected"><div class="stat-num" id="statRejected">—</div><div class="stat-label">Rejected</div></div>
      <div class="stat-card total"><div class="stat-num" id="statTotal">—</div><div class="stat-label">Total Requests</div></div>
