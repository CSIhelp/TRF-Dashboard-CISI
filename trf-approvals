</div>

<div class="toast" id="toast"></div>

<script>
// ── CONSTANTS ──
const BASE_URL       = 'https://primary-production-a810.up.railway.app/webhook';
const SUPERVISOR_URL = `${BASE_URL}/trf-action`;
const HR_URL         = `${BASE_URL}/trf-action-hr`;

// ── STATE ──
let currentRole     = null; // 'supervisor' | 'hr'
let allData         = [];
let filteredData    = [];
let currentFilter   = 'all';
let pendingTRF      = null; // TRF being actioned
let supervisorInfo  = null; // { name, email, department }

// ── ROLE CONFIG ──
// Map emails to roles — you can extend this
const SUPERVISOR_EMAILS = []; // Will be loaded from DB
const HR_EMAILS         = []; // Will be loaded from DB

// ── INIT ──
async function init() {
  await checkAuth();
  const email = window.currentUserEmail;
  document.getElementById('roleEmail').textContent = email;

  // Load role from DB
  await detectRole(email);
  renderSidebar();
  await loadApprovals();
}

async function detectRole(email) {
  try {
    const res  = await fetch(`${BASE_URL}/get-trf-user-role?email=${encodeURIComponent(email)}`);
    const data = await res.json();
    const info = Array.isArray(data) ? data[0] : data;

    // If the user is a supervisor, restrict to supervisor view
    // Otherwise ALL logged-in users get full HR access regardless of email
    if (info && info.role === 'supervisor') {
      currentRole    = 'supervisor';
      supervisorInfo = info;
      document.getElementById('topUserName').textContent = info.name || email;
      document.getElementById('topUserRole').textContent = 'Supervisor';
      document.getElementById('rolePill').textContent    = 'Supervisor';
      document.getElementById('rolePill').className      = 'role-pill supervisor';
      document.getElementById('roleDesc').textContent    = `Department: ${info.department || 'All'}`;
      document.getElementById('pageSubtitle').textContent = 'TRFs from your department pending your approval';
    } else {
      // Default: any logged-in user gets HR access
      currentRole    = 'hr';
      supervisorInfo = info || { name: email, email };
      document.getElementById('topUserName').textContent = (info && info.name) ? info.name : email;
      document.getElementById('topUserRole').textContent = 'HR Officer';
      document.getElementById('rolePill').textContent    = 'HR';
      document.getElementById('rolePill').className      = 'role-pill hr';
      document.getElementById('roleDesc').textContent    = 'Full HR approval access';
      document.getElementById('pageSubtitle').textContent = 'TRFs pending HR approval';
    }
  } catch {
    // On any error, default to HR access
    currentRole = 'hr';
    supervisorInfo = { name: email, email };
    document.getElementById('topUserName').textContent = email;
    document.getElementById('topUserRole').textContent = 'HR Officer';
    document.getElementById('rolePill').textContent    = 'HR';
    document.getElementById('rolePill').className      = 'role-pill hr';
    document.getElementById('roleDesc').textContent    = 'Full HR approval access';
  }
}

