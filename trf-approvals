<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TRF Approvals — CrowdSource</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script>
    const _supabaseUrl = 'https://vuycjivcpyncmaiikpfe.supabase.co';
    const _supabaseKey = 'sb_publishable_5StoCQqroJgcqn_Z4NDzqQ_LVXXHabG';
    const _supabase = window.supabase.createClient(_supabaseUrl, _supabaseKey);

    // Role-based auth — supervisors and HR only
    async function checkAuth() {
      const { data: { session }, error } = await _supabase.auth.getSession();
      if (!session || error) { window.location.replace('index.html'); return; }
      const email = session.user.email;
      // Store current user email for role check
      window.currentUserEmail = email;
    }
    checkAuth();
    async function logOut() { await _supabase.auth.signOut(); window.location.replace('index.html'); }
  </script>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#f4f5f7;--sidebar-bg:#fff;--topbar-bg:#1a1a2e;--accent:#1565c0;--accent-light:#e8f0fe;--text-primary:#1a1a2e;--text-secondary:#6b7280;--text-muted:#9ca3af;--border:#e5e7eb;--row-hover:#f9fafb;--radius:10px;--shadow-sm:0 1px 3px rgba(0,0,0,.07);--shadow-lg:0 10px 25px rgba(0,0,0,.1)}
    body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text-primary);min-height:100vh;display:flex;flex-direction:column}
    .topbar{background:var(--topbar-bg);display:flex;align-items:center;padding:0 28px;height:70px;gap:20px;flex-shrink:0}
    .logo{display:flex;align-items:center;gap:10px;text-decoration:none;flex-shrink:0}
    .logo-img{height:40px;width:auto;object-fit:contain}
    .logo-text{font-size:15px;font-weight:600;color:#fff;letter-spacing:.5px}
    .logo-text span{color:#64b5f6}
    .topbar-user{margin-left:auto;display:flex;align-items:center;gap:12px}
    .topbar-user-name{text-align:right;color:#fff;line-height:1.3}
    .topbar-user-name strong{display:block;font-size:13.5px;font-weight:600}
    .topbar-user-name span{font-size:12px;color:rgba(255,255,255,.55)}
    .avatar{width:40px;height:40px;background:rgba(255,255,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.8)}
    .layout{display:flex;flex:1;overflow:hidden}
    .sidebar{width:210px;background:var(--sidebar-bg);border-right:1px solid var(--border);display:flex;flex-direction:column;padding:20px 0;flex-shrink:0}
    .nav-item{display:flex;align-items:center;gap:11px;padding:10px 20px;font-size:13.5px;font-weight:500;color:var(--text-secondary);text-decoration:none;transition:background .15s,color .15s;cursor:pointer;border:none;background:none;width:100%;text-align:left;position:relative}
    .nav-item:hover{background:var(--accent-light);color:var(--accent)}
    .nav-item.active{color:var(--accent);background:var(--accent-light);font-weight:600}
    .nav-item svg{flex-shrink:0;opacity:.7}
    .nav-item.active svg{opacity:1}
    .nav-item .arrow{margin-left:auto;font-size:10px;transition:transform .2s;color:var(--text-muted)}
    .nav-item.open .arrow{transform:rotate(180deg)}
    .nav-badge{position:absolute;right:14px;top:50%;transform:translateY(-50%);background:#dc2626;color:#fff;font-size:10px;font-weight:700;padding:2px 6px;border-radius:10px;min-width:18px;text-align:center}
    .nav-divider{height:1px;background:var(--border);margin:12px 16px}
    .nav-bottom{margin-top:auto}
    .nav-group{display:flex;flex-direction:column;width:100%}
    .sub-nav{display:none;flex-direction:column;background:#fafbfc;border-bottom:1px solid var(--border)}
    .sub-nav.open{display:flex}
    .sub-nav-item{padding:10px 20px 10px 47px;font-size:13px;font-weight:500;color:var(--text-secondary);text-decoration:none;transition:background .15s,color .15s;border-left:3px solid transparent;cursor:pointer}
    .sub-nav-item:hover{color:var(--accent);background:var(--accent-light)}
    .sub-nav-item.active{color:var(--accent);font-weight:600;background:var(--accent-light);border-left-color:var(--accent)}
    .main{flex:1;overflow-y:auto;padding:28px 32px;display:flex;flex-direction:column;gap:20px}
    .page-header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
    .page-title{font-size:20px;font-weight:700}
    .page-subtitle{font-size:13px;color:var(--text-muted);margin-top:2px}

    /* ROLE BANNER */
    .role-banner{background:#1a1a2e;color:#fff;border-radius:var(--radius);padding:14px 20px;display:flex;align-items:center;gap:12px;font-size:13px}
    .role-banner strong{color:#64b5f6}
    .role-pill{background:rgba(255,255,255,.15);border-radius:20px;padding:3px 12px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em}
    .role-pill.supervisor{background:#1565c0}
    .role-pill.hr{background:#15803d}

    /* STATS */
    .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
    .stat-card{background:#fff;border-radius:var(--radius);border:1px solid var(--border);padding:18px 20px;box-shadow:var(--shadow-sm)}
    .stat-num{font-size:26px;font-weight:700;margin-bottom:4px}
    .stat-label{font-size:12px;color:var(--text-muted);font-weight:500;text-transform:uppercase;letter-spacing:.06em}
    .stat-card.pending .stat-num{color:#b45309}
    .stat-card.approved .stat-num{color:#15803d}
    .stat-card.rejected .stat-num{color:#dc2626}
    .stat-card.total .stat-num{color:var(--accent)}

    /* FILTER TABS */
    .filter-bar{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .filter-tab{padding:7px 16px;border-radius:20px;font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;border:none;background:#e3f2fd;color:#1565c0;transition:all .15s}
    .filter-tab:hover{background:#bbdefb}
    .filter-tab.active{background:#2196f3;color:#fff}
    .search-input{border:1.5px solid var(--border);border-radius:8px;padding:8px 14px;font-family:inherit;font-size:13px;width:220px;outline:none;transition:border .2s;margin-left:auto}
    .search-input:focus{border-color:var(--accent)}

    /* TABLE */
    .db-card{background:#fff;border-radius:var(--radius);border:1px solid var(--border);box-shadow:var(--shadow-sm);overflow:hidden}
    .table-scroll{overflow-x:auto}
    table{width:100%;border-collapse:collapse;text-align:left;min-width:700px}
    th{background:#fafbfc;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text-muted);padding:11px 14px;border-bottom:1px solid var(--border);white-space:nowrap}
    td{padding:11px 14px;font-size:12.5px;border-bottom:1px solid var(--border);vertical-align:middle;white-space:nowrap}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:var(--row-hover)}
    .badge{display:inline-block;font-size:10px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;padding:3px 9px;border-radius:20px}
    .badge-pending{background:#fff8e1;color:#b45309}
    .badge-approved{background:#e6f9f0;color:#15803d}
    .badge-rejected{background:#fef2f2;color:#dc2626}
    .badge-supervisor{background:#e8f0fe;color:#1565c0}
    .badge-hr{background:#f0fdf4;color:#15803d}
    .state-cell{text-align:center;padding:48px!important;color:var(--text-muted);font-size:13.5px}

    /* ACTION BUTTONS */
    .btn{display:inline-flex;align-items:center;gap:5px;border-radius:7px;padding:6px 12px;font-size:12px;font-weight:600;cursor:pointer;transition:all .15s;border:none;font-family:inherit;white-space:nowrap}
    .btn-approve{background:#e6f9f0;color:#15803d}
    .btn-approve:hover{background:#bbf7d0}
    .btn-reject{background:#fef2f2;color:#dc2626}
    .btn-reject:hover{background:#fecaca}
    .btn-view{background:#e8f0fe;color:#1565c0}
    .btn-view:hover{background:#bfdbfe}
    .btn-primary{background:var(--accent);color:#fff;padding:9px 18px;font-size:13px}
    .btn-primary:hover{background:#0f4c92}

    /* MODAL */
    .modal-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.4);display:none;justify-content:center;align-items:center;z-index:100;backdrop-filter:blur(2px)}
    .modal-overlay.active{display:flex}
    .modal{background:#fff;width:540px;max-width:92%;border-radius:12px;box-shadow:var(--shadow-lg);overflow:hidden;display:flex;flex-direction:column;max-height:90vh}
    .modal-header{padding:20px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-shrink:0}
    .modal-header h2{font-size:16px;font-weight:700}
    .modal-close{background:none;border:none;font-size:20px;cursor:pointer;color:var(--text-muted)}
    .modal-body{padding:20px;overflow-y:auto;display:flex;flex-direction:column;gap:14px}
    .modal-footer{padding:16px 20px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px;background:#fafbfc;flex-shrink:0}
    .detail-row{display:flex;justify-content:space-between;align-items:flex-start;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px}
    .detail-row:last-child{border-bottom:none}
    .detail-label{color:var(--text-secondary);font-weight:600;flex-shrink:0;margin-right:16px}
    .detail-value{color:var(--text-primary);text-align:right}
    .section-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text-muted);padding-bottom:6px;border-bottom:1px solid var(--border)}
    .form-group{display:flex;flex-direction:column;gap:5px}
    .form-group label{font-size:12px;font-weight:600;color:var(--text-secondary)}
    .form-group input,.form-group select,.form-group textarea{padding:9px 12px;border:1.5px solid var(--border);border-radius:6px;font-family:inherit;font-size:13px;color:var(--text-primary);outline:none;transition:border .2s}
    .form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--accent)}
    .form-group textarea{resize:vertical;min-height:80px}

    /* LEAVE SUMMARY STRIP */
    .leave-strip{display:grid;grid-template-columns:repeat(3,1fr);gap:0;background:#f0f9ff;border:1px solid #bae6fd;border-radius:8px;overflow:hidden;margin-bottom:4px}
    .leave-strip-item{padding:12px;text-align:center;border-right:1px solid #bae6fd}
    .leave-strip-item:last-child{border-right:none}
    .leave-strip-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#0369a1;margin-bottom:4px}
    .leave-strip-val{font-size:18px;font-weight:700;color:#0c4a6e}
    .leave-strip-unit{font-size:10px;color:#0369a1}

    .spinner{display:inline-block;width:14px;height:14px;border:2px solid #ccc;border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite}
    @keyframes spin{to{transform:rotate(360deg)}}
    .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:#1a1a2e;color:#fff;font-size:13px;font-weight:500;padding:12px 24px;border-radius:8px;display:flex;align-items:center;gap:8px;z-index:9999;opacity:0;transition:transform .35s,opacity .3s;white-space:nowrap}
    .toast.show{transform:translateX(-50%) translateY(0);opacity:1}
    .toast.success{background:#16a34a}
    .toast.error{background:#dc2626}

    @media(max-width:1024px){.stats-grid{grid-template-columns:repeat(2,1fr)}}
  </style>
</head>
<body>

<header class="topbar">
  <a class="logo" href="homepage.html"><img src="favicon.ico" alt="" class="logo-img" onerror="this.style.display='none'"><span class="logo-text"><span>CROWD</span>SOURCE</span></a>
  <div class="topbar-user">
    <div class="topbar-user-name"><strong id="topUserName">Loading...</strong><span id="topUserRole">—</span></div>
    <div class="avatar"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
  </div>
</header>

<div class="layout">
  <nav class="sidebar" id="sidebarNav">
    <!-- Rendered by JS based on role -->
  </nav>

  <main class="main">
    <div class="page-header">
      <div>
        <div class="page-title">TRF Approvals</div>
        <div class="page-subtitle" id="pageSubtitle">Loading your approval queue...</div>
      </div>
      <button class="btn btn-primary" onclick="loadApprovals()">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
        Refresh
      </button>
    </div>

    <div class="role-banner">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      <span>Logged in as <strong id="roleEmail">—</strong></span>
